# ==========================================
# Skywin Server Environment Configuration
# ==========================================

# Application
NODE_ENV=development
PORT=3001

# Database (set to false to use fallback data without MongoDB)
# MongoDB Atlas Connection (replace <db_password> with your actual password)
DATABASE_URL=mongodb+srv://dbuser:<db_password>@cluster0.efzbkhn.mongodb.net/skywin?retryWrites=true&w=majority
# Local MongoDB (fallback)
# DATABASE_URL=mongodb://localhost:27017/skywin
ENABLE_DB=true

# Authentication (JWT) - CRITICAL: Change in production!
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-different-refresh-secret-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# CORS (comma-separated list for multiple origins)
CORS_ORIGIN=http://localhost:3003
