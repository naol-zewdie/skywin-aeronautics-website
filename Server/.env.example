# ==========================================
# Skywin Server Environment Configuration
# ==========================================

# Application
NODE_ENV=development
PORT=3001

# Database (set to false to use fallback data without MongoDB)
DATABASE_URL=mongodb://localhost:27017/skywin
ENABLE_DB=false

# Authentication (JWT)
JWT_SECRET=skywin-super-secret-jwt-key-2024-secure
JWT_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3003
